# Clé secrète pour la signature des jetons JWT (min. 32 caractères)
JWT_SECRET=

# ─── Assistant IA (route POST /gti525/v1/assistant) ─────────────────────────
# Fournisseur LLM. Tous offrent un palier GRATUIT :
#   gemini  -> https://aistudio.google.com/apikey   (gratuit, sans carte)
#   groq    -> https://console.groq.com/keys        (gratuit, compatible OpenAI)
#   mistral -> https://console.mistral.ai/api-keys  (palier gratuit)
LLM_PROVIDER=gemini

# Clé d'API du fournisseur choisi (reste côté serveur, jamais exposée à la frontale)
LLM_API_KEY=

# Modèle (optionnel — un défaut raisonnable est utilisé selon le fournisseur)
# gemini  -> gemini-2.0-flash
# groq    -> llama-3.1-8b-instant
# mistral -> mistral-small-latest
# LLM_MODEL=

# Limitation de débit de l'assistant (optionnel)
# ASSISTANT_RATE_MAX=15
# ASSISTANT_RATE_WINDOW_MS=60000
